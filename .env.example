# ── Existing FITON variables ───────────────────────────────────────────────────
POSTGRES_USER=fiton
POSTGRES_PASSWORD=fiton
POSTGRES_DB=fiton
SECRET_KEY=changeme

# ── ElevenLabs ─────────────────────────────────────────────────────────────────
# API key from https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Model slug for ElevenLabs Scribe v2 Realtime.
# TODO: Confirm the exact identifier from the ElevenLabs docs.
ELEVENLABS_SCRIBE_MODEL=scribe_v2_realtime

# ── Anthropic / Claude ─────────────────────────────────────────────────────────
# API key from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Claude model name used for argument generation.
# TODO: Update to the latest recommended model before shipping.
CLAUDE_MODEL=claude-opus-4-5

# Maximum tokens Claude emits per argument/counterargument stream.
CLAUDE_MAX_TOKENS=512

# ── Conversation analysis ──────────────────────────────────────────────────────
# Seconds of silence that signal a speaker's turn is complete.
SILENCE_TIMEOUT_SECONDS=2.0

# Minimum words in a turn before argument generation is triggered.
MIN_TURN_WORDS=5

# ── Frontend (Next.js) ─────────────────────────────────────────────────────────
# WebSocket URL the browser connects to. Change host/port in production.
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/conversation
