# ── Database (used by compose.yaml for the Postgres container) ────────────────
POSTGRES_USER=fiton
POSTGRES_PASSWORD=fiton
POSTGRES_DB=fiton

# ── Anthropic / Claude ─────────────────────────────────────────────────────────
# API key from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Claude model used for argument generation.
CLAUDE_MODEL=claude-opus-4-5

# Maximum tokens Claude emits per argument/counterargument stream.
CLAUDE_MAX_TOKENS=512

# ── Conversation analysis ──────────────────────────────────────────────────────
# Minimum words in a turn before argument generation is triggered.
MIN_TURN_WORDS=5

# ── Frontend (Next.js) ─────────────────────────────────────────────────────────
# WebSocket URL the browser connects to. Keep as localhost for local dev.
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/conversation

# ── Speaker diarization (pyannote.audio) ──────────────────────────────────────
# Required — the model is gated on HuggingFace.
# Setup (takes ~2 minutes):
#   1. Create a read token at huggingface.co/settings/tokens
#   2. Accept model terms at:
#        huggingface.co/pyannote/speaker-diarization-3.1
#        huggingface.co/pyannote/segmentation-3.0
#        huggingface.co/pyannote/embedding
HF_TOKEN=
